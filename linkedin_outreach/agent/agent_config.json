{
  "agent_id": "outreach_supervisor_v1",
  "name": "LinkedIn Outreach Supervisor",
  "description": "Supervised orchestration agent that coordinates queue preparation, human review, and send workflows for the linkedin_outreach system. Enforces safety rules (daily caps, delays, CAPTCHA halts, human approvals). Does NOT send messages autonomously.",
  "owner": "Atin Sharma",
  "run_commands": {
    "prepare": "npm run prepare",
    "review": "npm run review",
    "send": "npm run send",
    "agent_runner": "npm run agent:run",
    "gmail_invoker": "npm run gmail:invoke"
  },
  "storage_paths": {
    "root": "./",
    "templates": "templates/",
    "contacts": "contacts/targets.csv",
    "queue_pending": "queue/pending.json",
    "queue_approved": "queue/approved.json",
    "queue_sent": "queue/sent.json",
    "logs": "logs/",
    "blacklist": "queue/blacklist.json"
  },
  "safety": {
    "require_human_confirmation": true,
    "daily_send_limit": 15,
    "min_delay_ms": 45000,
    "max_delay_ms": 90000,
    "halt_on_captcha_or_security_alert": true,
    "never_store_credentials": true,
    "only_process_status": "approved",
    "max_parallel_sends": 1,
    "require_personalization_check": true,
    "min_personalization_score": 2
  },
  "persona_scope": [1,2,3,4,5],
  "notification": {
    "enabled": true,
    "channels": ["gmail"],
    "notification_email": "atinsharma24@gmail.com",
    "trigger_subject": "RUN OUTREACH"
  },
  "audit": {
    "log_file": "logs/outreach.log",
    "errors_file": "logs/errors.log"
  },
  "created_at": "2026-04-11T00:00:00Z",
  "version": "1.1.0"
}
